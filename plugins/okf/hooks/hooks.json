{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "ruby",
            "args": ["${PLUGIN_ROOT}/hooks/curate.rb"],
            "timeout": 20,
            "statusMessage": "Checking OKF curation"
          }
        ]
      }
    ]
  }
}
